gameshow.thecultofbrighterdays.org {
    root * /srv/gameshow
    encode gzip zstd

    # Node server handles uploads and git webhook
    handle /upload {
        reverse_proxy 127.0.0.1:3456
    }
    handle /webhook {
        reverse_proxy 127.0.0.1:3456
    }

    # Caddy browse JSON for the game library
    handle /jeopardy/games/* {
        file_server {
            browse
            hide *.md
        }
    }

    # Everything else: static files
    handle {
        file_server {
            hide .git* Caddyfile.example *.md
        }
    }
}
