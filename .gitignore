# Audio binaries are downloaded locally per jeopardy/sounds/README.md.
# Keeping them out of the repo keeps it lean and avoids stock-audio
# redistribution terms (e.g. Mixkit) on a public GitHub repo.
jeopardy/sounds/*.mp3
jeopardy/sounds/*.wav
jeopardy/sounds/*.ogg
jeopardy/sounds/*.m4a

